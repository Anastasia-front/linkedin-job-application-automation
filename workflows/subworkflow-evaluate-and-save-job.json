              "value": "={{\n(() => {\n  const s = $json.baseSalary || $json.salary || {};\n  const v = s?.value;\n\n  const fallback =\n    $('Extract Job ID').item.json.salary ||\n    $('Extract Job ID').item.json.salary_range;\n\n  if (!v) return fallback || '-';\n\n  let parts = [];\n\n  if (v.minValue != null && v.maxValue != null) {\n    parts.push(`${v.minValue} - ${v.maxValue}`);\n  } else if (v.minValue != null) {\n    parts.push(`${v.minValue}`);\n  } else if (v.maxValue != null) {\n    parts.push(`${v.maxValue}`);\n  }\n\n  let result = parts.join('');\n\n  if (s.currency) result += ` ${s.currency}`;\n  if (s.unitText || v.unitText) {\n    result += ` (per ${s.unitText || v.unitText})`;\n  }\n\n  return result.trim() || fallback || '-';\n})()\n}}",
              "type": "string"
            },
            {
              "id": "dca7a46f-eb25-4e32-b8df-8d0035cf2360",
              "name": "link",
              "value": "={{ $('Extract Job ID').item.json.jobUrl || $('Extract Job ID').item.json.job_url ||$('Extract Job ID').item.json.link || $json.url || $json.jobUrl || $json.linkedinUrl || $json.hiringOrganization?.sameAs || $('Loop Over Items').item.json.jobUrl || '-' }}",
              "type": "string"
