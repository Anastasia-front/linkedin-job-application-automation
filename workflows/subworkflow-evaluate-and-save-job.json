        "jsCode": "const html = $json.data || $json.html || $json.body || \"\";\n\n// ==========================================\n// 1. EXTRACT DESCRIPTION\n// ==========================================\nlet description = \"\";\nconst descriptionRegexes = [\n  /<div class=\"show-more-less__list[^>]*>([\\s\\S]*?)<\\/div>/i,\n  /<span class=\"description__content[^>]*>([\\s\\S]*?)<\\/span>/i,\n  /<div class=\"description__text[^>]*>([\\s\\S]*?)<\\/div>/i,\n  /<div class=\"mt4[^>]*>([\\s\\S]*?)(?=<\\/div>)/i\n];\n\nfor (const regex of descriptionRegexes) {\n  const match = html.match(regex);\n  if (match && match[1]) {\n    description = match[1];\n    break;\n  }\n}\n\n// Clean HTML tags and normalize spacing\ndescription = description\n  .replace(/<[^>]+>/g, \" \")\n  .replace(/\\s+/g, \" \")\n  .trim();\n\n// ==========================================\n// 2. SAFE RESOLUTION & DOUBLE QUOTE REPLACEMENT\n// ==========================================\nlet finalDescription = description || $json.description || \"-\";\n\n// Replace any stray double quotes inside strings with single quotes\n// This prevents them from ruining your downstream LLM JSON formats!\nfinalDescription = finalDescription.replace(/\"/g, \"'\");\n\nreturn {\n  description: finalDescription\n};"
      },
